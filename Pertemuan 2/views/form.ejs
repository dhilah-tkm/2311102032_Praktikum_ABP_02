<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Tambah Tugas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-primary mb-4">
        <div class="container">
            <span class="navbar-brand mb-0 h1">Agenda Mata Kuliah</span>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow p-4 mx-auto" style="max-width: 600px;">
            <h3>Input Tugas Baru</h3>
            <hr>
            <form id="formProject">
                <div class="mb-3">
                    <label>Mata Kuliah</label>
                    <input type="text" id="matkul" class="form-control" required placeholder="Contoh: Matematika Diskrit">
                </div>
                <div class="mb-3">
                    <label>Nama Tugas</label>
                    <input type="text" id="tugas" class="form-control" required placeholder="Contoh: Latihan Logika Fuzzy">
                </div>
                <div class="mb-3">
                    <label>Deadline</label>
                    <input type="date" id="deadline" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label>Prioritas</label>
                    <select id="prioritas" class="form-select">
                        <option>Rendah</option>
                        <option selected>Sedang</option>
                        <option>Tinggi</option>
                    </select>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Simpan Tugas</button>
                    <a href="/" class="btn btn-secondary">Kembali</a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $('#formProject').on('submit', function(e) {
            e.preventDefault();
            const data = {
                matkul: $('#matkul').val(),
                tugas: $('#tugas').val(),
                deadline: $('#deadline').val(),
                prioritas: $('#prioritas').val()
            };
            $.post('/api/projects', data, function() {
                alert('Tugas berhasil ditambahkan!');
                window.location.href = '/';
            });
        });
    </script>
</body>
</html>